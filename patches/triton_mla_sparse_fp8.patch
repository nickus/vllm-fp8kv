+    sgn = (u & 0x80) << 8
+    mag = (u & 0x7F) << 7
+    val = (sgn | mag).to(tl.float16, bitcast=True) * 256.0
+    nan = (sgn | 0x7F80).to(tl.float16, bitcast=True)
+    return tl.where((u & 0x7F) == 0x7F, nan, val.to(tl.float16))
